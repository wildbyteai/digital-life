{
  "skill": "cringe-archaeology",
  "version": "1.0.0",
  "output_format": {
    "timeline": {
      "type": "array",
      "description": "社死时间线，按时间排列",
      "items": {
        "date": { "type": "string", "format": "date" },
        "platform": { "type": "string" },
        "type": { "type": "string", "description": "内容类型（日志/说说/回复/签名）" },
        "content": { "type": "string", "description": "原始内容" },
        "cringe_score": { "type": "integer", "min": 0, "max": 100, "description": "社死指数" },
        "authenticity_score": { "type": "integer", "min": 0, "max": 100, "description": "本真指数" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "comment": { "type": "string", "description": "考古学家的一句话点评" }
      }
    },
    "dual_scores": {
      "avg_cringe": { "type": "integer", "min": 0, "max": 100 },
      "avg_authenticity": { "type": "integer", "min": 0, "max": 100 },
      "correlation": { "type": "string", "description": "社死与本真的相关性描述" },
      "peak_cringe_year": { "type": "integer" },
      "peak_authenticity_year": { "type": "integer" },
      "mars_text_ratio": { "type": "number", "min": 0, "max": 1, "description": "火星文占比" }
    },
    "mask_turning_point": {
      "year": { "type": "integer", "description": "开始学会表演体面的年份" },
      "evidence": { "type": "string", "description": "转折点的具体证据" },
      "before_style": { "type": "string", "description": "转折前的表达风格" },
      "after_style": { "type": "string", "description": "转折后的表达风格" }
    },
    "authenticity_analysis": {
      "authenticity_decline": { "type": "string", "description": "本真度下降曲线描述" },
      "lost_expressions": { "type": "array", "items": { "type": "string" }, "description": "你不再用的表达方式" },
      "final_question": { "type": "string", "description": "结尾的存在追问" }
    }
  }
}
