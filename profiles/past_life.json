{
  "skill": "past-life",
  "version": "1.0.1",
  "persona_layers": {
    "layer_0": {
      "source": "layer0/past_life.md",
      "description": "硬规则：不可违背的行为准则（agent 直接读取文件）"
    },
    "layer_1": {
      "past_identity": {
        "era": { "type": "string", "description": "前世的时代（如：清末、明末、民国初年）" },
        "location": { "type": "string", "description": "前世的地点（如：江南小镇、西北边塞、京城）" },
        "occupation": { "type": "string", "description": "前世的职业/身份（如：书店老板、更夫、账房先生）" },
        "death_cause": { "type": "string", "description": "前世的死因（隐喻性质，需与行为模式对应）" },
        "death_age": { "type": "integer", "description": "前世死时的年龄（可选）" },
        "summary": { "type": "string", "description": "前世身份的一句话描述" }
      },
      "current_identity": {
        "age_range": { "type": "string", "description": "今世年龄段（如：25-30）" },
        "occupation": { "type": "string", "description": "今世职业" },
        "relationship_status": { "type": "string", "description": "关系状态" },
        "digital_lifespan": { "type": "string", "description": "数字生活跨度（如：从 2008 年至今）" }
      }
    },
    "layer_2": {
      "behavior_patterns": {
        "description": "从前世印记继承的行为模式清单",
        "items": {
          "pattern_name": { "type": "string", "description": "行为模式名称（如：夜间警戒）" },
          "manifestation": { "type": "string", "description": "今生的具体表现（如：凌晨 2 点还在刷手机）" },
          "trigger_condition": { "type": "string", "description": "什么情况下会被激活（如：独自在家的夜晚）" },
          "past_origin": { "type": "string", "description": "前世的来源（如：更夫守夜的经历）" },
          "severity": { "type": "string", "description": "严重程度：轻/中/重" }
        }
      }
    },
    "layer_3": {
      "cognitive_biases": {
        "description": "前世遗留的决策偏见",
        "items": {
          "bias_name": { "type": "string", "description": "偏见名称（如：过度谨慎）" },
          "past_origin": { "type": "string", "description": "前世来源" },
          "today_manifestation": { "type": "string", "description": "今天的具体表现" },
          "cost": { "type": "string", "description": "这个偏见的代价" }
        }
      },
      "karmic_debt": {
        "description": "业力债务清单",
        "items": {
          "habit": { "type": "string", "description": "这辈子的坏习惯" },
          "debt_level": { "type": "string", "description": "业力等级（轻/中/重）" },
          "karmic_origin": { "type": "string", "description": "前世来源" },
          "life_cost": { "type": "string", "description": "生命成本换算（如：61 天的人生）" },
          "repayment": { "type": "string", "description": "偿债方式（具体可执行动作）" }
        }
      }
    },
    "layer_4": {
      "emotional_triggers": {
        "description": "前世印记导致的情绪触发器",
        "items": {
          "trigger": { "type": "string", "description": "触发条件（如：被人质疑）" },
          "reaction": { "type": "string", "description": "自动反应（如：退缩/反驳/讨好）" },
          "past_origin": { "type": "string", "description": "前世的来源" },
          "alternative_response": { "type": "string", "description": "建议的替代反应（打破循环）" }
        }
      },
      "protective_mechanisms": {
        "description": "前世留下的自我保护机制",
        "items": {
          "mechanism": { "type": "string", "description": "保护机制名称（如：逃避、讨好、控制）" },
          "what_protects_against": { "type": "string", "description": "保护你免受什么" },
          "side_effect": { "type": "string", "description": "副作用是什么" },
          "when_to_keep": { "type": "string", "description": "什么时候应该保留这个机制" },
          "when_to_release": { "type": "string", "description": "什么时候可以释放这个机制" }
        }
      }
    }
  },
  "evolution": {
    "version": { "type": "integer", "description": "当前版本号" },
    "created_at": { "type": "string", "format": "ISO datetime" },
    "updated_at": { "type": "string", "format": "ISO datetime" },
    "history": {
      "type": "array",
      "description": "变更历史（追加/纠正）",
      "items": {
        "version": { "type": "integer" },
        "timestamp": { "type": "string", "format": "ISO datetime" },
        "type": { "type": "string", "enum": ["append", "correction", "reset"] },
        "target_layer": { "type": "string", "description": "变更的 Persona 层" },
        "target_field": { "type": "string", "description": "变更的字段" },
        "old_value": { "type": "string", "description": "旧值（仅纠正模式）" },
        "new_value": { "type": "string", "description": "新值" },
        "reason": { "type": "string", "description": "变更原因" }
      }
    }
  },
  "evidence_chain": {
    "type": "array",
    "description": "因果链——这辈子的行为 ← 前世的对应",
    "items": {
      "this_life_trait": { "type": "string", "description": "这辈子的特征/行为" },
      "past_life_origin": { "type": "string", "description": "前世的对应/来源" },
      "evidence": { "type": "string", "description": "具体证据" }
    }
  },
  "cycle_breaking": {
    "type": "array",
    "description": "打破循环的建议（至少 3 条，每条必须可执行）",
    "items": {
      "cycle": { "type": "string", "description": "需要打破的循环" },
      "first_step": { "type": "string", "description": "第一步动作（今天/本周就能做）" },
      "expected_outcome": { "type": "string", "description": "做完之后会怎样" }
    }
  },
  "final_question": {
    "type": "string",
    "description": "结尾的存在追问（必须与用户的前世推演直接相关）"
  }
}
